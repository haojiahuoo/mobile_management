<h2>📈 销售趋势图（最近数据）</h2>

<canvas id="salesChart" width="800" height="300"></canvas>

<!-- 安全注入数据（推荐写法） -->
{{ chart_dates|json_script:"chart-dates" }}
{{ chart_sales|json_script:"chart-sales" }}
{{ chart_profits|json_script:"chart-profits" }}

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

    // ✅ 从 JSON script 读取数据（安全、不会报错）
    const dates = JSON.parse(document.getElementById('chart-dates').textContent);
    const sales = JSON.parse(document.getElementById('chart-sales').textContent);
    const profits = JSON.parse(document.getElementById('chart-profits').textContent);

    // ✅ 防御：没有数据时避免崩溃
    if (!dates.length) {
        console.warn("暂无销售数据");
        return;
    }

    const ctx = document.getElementById('salesChart').getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: dates,
            datasets: [
                {
                    label: '销售额',
                    data: sales,
                    tension: 0.3,              // 曲线平滑
                    fill: false,
                },
                {
                    label: '利润',
                    data: profits,
                    tension: 0.3,
                    fill: false,
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,

            plugins: {
                legend: {
                    position: 'top',
                },
                tooltip: {
                    mode: 'index',
                    intersect: false
                }
            },

            interaction: {
                mode: 'nearest',
                axis: 'x',
                intersect: false
            },

            scales: {
                x: {
                    title: {
                        display: true,
                        text: '日期'
                    }
                },
                y: {
                    title: {
                        display: true,
                        text: '金额'
                    },
                    beginAtZero: true
                }
            }
        }
    });

});
</script>

<h3>📅 最近7天统计</h3>

<table border="1" cellpadding="8" style="border-collapse: collapse; width: 100%;">
    <thead style="background:#f5f5f5;">
        <tr>
            <th>日期</th>
            <th>销售额</th>
            <th>利润</th>
        </tr>
    </thead>

    <tbody>
        {% for item in daily_data %}
        <tr>
            <td>{{ item.date }}</td>
            <td>{{ item.total_sales }}</td>
            <td>{{ item.total_profit }}</td>
        </tr>
        {% empty %}
        <tr>
            <td colspan="3" style="text-align:center;">暂无数据</td>
        </tr>
        {% endfor %}
    </tbody>
</table>